# Copy to .env and adjust.
#
# For Node on your host against Docker Compose, you can instead copy
# `.env.local.example` to `.env.local` (gitignored); see `backend/index.js`.

DATABASE_URL=postgresql://admin:admin@localhost:5433/openagrinet

JWT_SECRET=change-me-in-production

# Set KEYCLOAK_ENABLED=false to use only Postgres users (/api/login bcrypt).
KEYCLOAK_ENABLED=true
KEYCLOAK_URL=http://localhost:8090
KEYCLOAK_REALM=openagrinet
KEYCLOAK_CLIENT_ID=openagrinet-web
