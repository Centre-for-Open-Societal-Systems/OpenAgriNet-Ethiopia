# -----------------------------------------------------------------------------
# Deploy / production values for `vite build` (e.g. on AWS). Edit URLs here for
# your live environment.
#
# Local `npm run dev` loads `.env.development` after this file, which overrides
# VITE_APP_URL and VITE_KEYCLOAK_URL for Docker (Keycloak on host port 8090).
# -----------------------------------------------------------------------------

# Frontend URL
VITE_APP_URL=http://localhost:5173

# Port for Vite
VITE_PORT=5173

# Keycloak config
VITE_KEYCLOAK_CLIENT_ID=openagrinet-web
VITE_KEYCLOAK_REALM=openagrinet
VITE_KEYCLOAK_URL=http://localhost:8081

DB_HOST=localhost
DB_PORT=5433
DB_NAME=syncc
DB_USER=odoo
DB_PASSWORD=odoo
